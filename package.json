{
  "name": "react-ts-interview",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "html-minifier-terser": "^7.2.0",
    "terser": "^5.46.0",
    "vite": "^4.5.0"
  },
  "scripts": {
    "dev": "vite",
    "minify-sandbox": "html-minifier-terser src/sandbox/react-sandbox.html --output src/sandbox/react-sandbox.min.html --collapse-whitespace --remove-comments --remove-empty-attributes --remove-redundant-attributes --remove-script-type-attributes --remove-tag-whitespace --minify-css true --minify-js \"{}\"",
    "minify-sandbox-tasks-answers": "html-minifier-terser src/sandbox/react-sandbox-tasks-answers.html --output src/sandbox/react-sandbox-tasks-answers.min.html --collapse-whitespace --remove-comments --remove-empty-attributes --remove-redundant-attributes --remove-script-type-attributes --remove-tag-whitespace --minify-css true --minify-js \"{}\""
  }
}
